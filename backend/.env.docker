NODE_ENV=production
PORT=5000
API_VERSION=v1

DB_HOST=db
DB_PORT=5432
DB_NAME=intern_db
DB_USER=postgres
DB_PASSWORD=postgres

DB_POOL_MIN=2
DB_POOL_MAX=10

JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

CORS_ORIGIN=http://localhost

LOG_LEVEL=info